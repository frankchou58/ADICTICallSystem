# ---- Third-party SDK (WebView2) ----
# build/native/{include,x64,x86} IS vendored in git (this native MFC project has no
# NuGet restore configured) - see doc/ADICTICallCenter-MFC改版說明.md for details.
# The lines below re-include the two subfolders that would otherwise be swallowed by
# the generic x64/ and x86/ build-artifact rules above, and explicitly exclude the
# unused pieces of the nupkg (other platforms, managed/WinRT projections) so nobody
# re-vendors them by accident. To bump the SDK version, see
# ADICTICallCenter/ADICTICallCenter/third_party/Fetch-WebView2Sdk.ps1.
!ADICTICallCenter/ADICTICallCenter/third_party/WebView2/build/native/x64/
!ADICTICallCenter/ADICTICallCenter/third_party/WebView2/build/native/x86/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/build/native/arm64/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/build/native/include-winrt/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/lib/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/lib_manual/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/runtimes/
ADICTICallCenter/ADICTICallCenter/third_party/WebView2/tools/

# ---- Sensitive local config (real DB credentials - see config.local.php.example) ----
ADICTICallSystem.API/config/config.local.php

# ---- Runtime data, not source (real customer call recordings) ----
OperatorWeb/20220103/

# ---- OS / editor cruft ----
Thumbs.db
.DS_Store

# ---- Claude Code session state (not project source) ----
.claude/
